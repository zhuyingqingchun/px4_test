# Session / paths
SESSION_NAME="px4dev"
PX4_DIR="$HOME/PX4-Autopilot"
ROS_WS="px4_ros2_ws"
QGC_APPIMAGE="$HOME/QGroundControl-x86_64.AppImage"

# Simulator
PX4_TARGET="gz_x500"
HEADLESS=0
TMUX_LAYOUT="windows"
GZ_MODE="managed"

# Micro XRCE-DDS Agent
ENABLE_AGENT=1
AGENT_CMD=""
AGENT_ARGS="udp4 -p 8888"

# ROS 2
ROS_DISTRO="jazzy"
ENABLE_ROS=1
OFFBOARD_CMD="ros2 run my_px4_offboard offboard_trajectory --ros-args -p takeoff_height_m:=3.0 -p initial_hover_sec:=5.0 -p trajectory_type:=circle -p trajectory_radius_m:=1.0 -p trajectory_period_sec:=30.0 -p setpoint_rate_hz:=20.0 -p yaw_deg:=0.0"
ROS_SETUP_EXTRA=""

# QGroundControl
ENABLE_QGC=1
QGC_ENV="QT_QUICK_BACKEND=software QT_OPENGL=software LIBGL_ALWAYS_SOFTWARE=1"

# Startup / readiness
PX4_READY_TIMEOUT=120
QGC_SETTLE_SECONDS=6
ROS_TOPIC_WAIT_SECONDS=30
WAIT_FOR_FMU_TOPICS=1

# Optional safety guards
DETECT_EXISTING_GZ=1
FAIL_ON_EXISTING_GZ_IN_MANAGED=1

# Logs / runtime
LOG_DIR="px4_session_logs"
RUNTIME_DIR=".px4_one_click"
LOG_TERMINAL_MODE="concise"
ALERT_CONTEXT_LINES=6

# Clean behavior
REMOVE_PX4_BUILD=1
REMOVE_GZ_CACHE=0
REMOVE_QGC_CACHE=0
REMOVE_ROS_LOG=0