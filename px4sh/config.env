# Minimal tmux-based PX4 scripts, no custom logging system.

SESSION_NAME="px4_stack"

PX4_DIR="/home/tz/PX4-Autopilot"
ROS_WS="/home/tz/PX4_pro/px4_ros2_ws"
QGC_APPIMAGE="/home/tz/QGroundControl-x86_64.AppImage"

PX4_TARGET="gz_x500"
HEADLESS=0

ENABLE_AGENT=1
AGENT_CMD="/usr/local/bin/MicroXRCEAgent"
AGENT_ARGS="udp4 -p 8888"
AGENT_START_WAIT_SECONDS=2

# QGC 常驻，脚本不管理
ENABLE_QGC=0
QGC_ENV=""
QGC_START_WAIT_SECONDS=0

# 默认开 ROS
ENABLE_ROS=1
ROS_DISTRO="jazzy"
ROS_SETUP_EXTRA=""

# UGV 模式选择: "only" (仅UGV) 或 "coop" (空地协同)
DEFAULT_UGV_MODE="coop"

# UGV 轨迹配置: "rover_square.yaml" 或 "rover_out_and_back.yaml"
UGV_CONFIG="rover_out_and_back.yaml"

# 根据模式选择启动命令
# - 空地协同模式: 启动 UAV + UGV (BCR Bot版本，空场景)
# - 仅UGV模式: 只启动 BCR Bot
OFFBOARD_CMD="ros2 launch air_ground_playground air_ground_with_bcr.launch.py ugv_config:=/home/tz/PX4_pro/px4_ros2_ws/install/air_ground_playground/share/air_ground_playground/config/${UGV_CONFIG}"

# 如需仅启动UGV，手动运行:
# ros2 launch air_ground_playground vendor_bcr_only.launch.py
# 或使用DiffBot:
# ros2 launch air_ground_playground air_ground_with_gz_diffbot.launch.py

ROS_START_WAIT_SECONDS=2

PX4_PROCESS_WAIT_SECONDS=25
GZ_PROCESS_WAIT_SECONDS=25
PX4_STABILIZE_WAIT_SECONDS=18

DEFAULT_ATTACH_WINDOW="px4"