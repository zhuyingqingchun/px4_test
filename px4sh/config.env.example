# Copy to config.env and edit.

# Session / paths
SESSION_NAME="px4dev"
PX4_DIR="../PX4-Autopilot"
ROS_WS="px4_ros2_ws"
QGC_APPIMAGE="../QGroundControl-x86_64.AppImage"

# Simulator
PX4_TARGET="gz_x500"
GZ_MODE="managed"   # managed: PX4 starts Gazebo; standalone: set GZ_SERVER_CMD yourself
HEADLESS=0
TMUX_LAYOUT="windows"

# Micro XRCE-DDS Agent
# Leave AGENT_CMD empty to auto-discover, or set an explicit binary path/name.
ENABLE_AGENT=1
AGENT_CMD=""
AGENT_ARGS="udp4 -p 8888"

# ROS 2
ROS_DISTRO="jazzy"
ENABLE_ROS=1
# OFFBOARD_CMD should be the runnable command only.
# Do NOT source /opt/ros/... or .../install/setup.bash here.
OFFBOARD_CMD="ros2 run my_px4_offboard offboard_takeoff_hover"
ROS_SETUP_EXTRA=""
WAIT_FOR_FMU_TOPICS=1

# QGroundControl
ENABLE_QGC=1
QGC_ENV=""

# Timing / wait controls
AGENT_START_WAIT_SECONDS=2
PX4_READY_TIMEOUT=120
QGC_SETTLE_SECONDS=6
ROS_TOPIC_WAIT_SECONDS=30

# Logs / runtime
LOG_DIR="px4_session_logs"
RUNTIME_DIR=".px4_one_click"
LOG_TERMINAL_MODE="concise"
ALERT_CONTEXT_LINES=6
READ_LOG_LINES=200

# Full log retention:
# - PX4 keeps a retained tail by default so alert context stays available without unbounded growth.
# - Set PX4_DISABLE_FULL_LOG=1 to disable PX4 full log completely.
# - Non-PX4 components default to classic capped full logs unless you set STREAM_LOG_FULL_TAIL_LINES.
PX4_DISABLE_FULL_LOG=0
PX4_FULL_LOG_TAIL_LINES=4000
PX4_FULL_LOG_TRIM_EVERY=200
STREAM_LOG_FULL_TAIL_LINES=0
STREAM_LOG_FULL_TRIM_EVERY=200

# Clean behavior
REMOVE_PX4_BUILD=1
REMOVE_GZ_CACHE=0
REMOVE_QGC_CACHE=0
REMOVE_ROS_LOG=0
