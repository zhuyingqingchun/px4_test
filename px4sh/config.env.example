# Copy to config.env and edit.

# Session / paths
SESSION_NAME="px4dev"
PX4_DIR="../PX4-Autopilot"
ROS_WS="../px4_ros2_ws"
QGC_APPIMAGE="../QGroundControl-x86_64.AppImage"

# Simulator
PX4_TARGET="gz_x500"
HEADLESS=0
TMUX_LAYOUT="windows"

# Micro XRCE-DDS Agent
AGENT_CMD="micro-xrce-dds-agent"
AGENT_ARGS="udp4 -p 8888"

# ROS 2
ROS_DISTRO="jazzy"
ENABLE_ROS=1
# Example:
# OFFBOARD_CMD="ros2 run px4_ros_com offboard_control"
OFFBOARD_CMD=""
ROS_SETUP_EXTRA=""

# QGroundControl
ENABLE_QGC=1

# Start timing (seconds)
AGENT_WAIT=2
PX4_WAIT=10
QGC_WAIT=3
ROS_WAIT=1

# Logs / runtime
LOG_DIR="../px4_session_logs"
RUNTIME_DIR="../.px4_one_click"
LOG_TERMINAL_MODE="concise"
ALERT_CONTEXT_LINES=6

# Clean behavior
REMOVE_PX4_BUILD=1
REMOVE_GZ_CACHE=0
REMOVE_QGC_CACHE=0
REMOVE_ROS_LOG=0