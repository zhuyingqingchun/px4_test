# Runtime configuration template (copy to config.env and edit)

# Session / paths
SESSION_NAME="px4_stack"
PX4_DIR="~/PX4-Autopilot"
ROS_WS="~/PX4_pro/px4_ros2_ws"
QGC_APPIMAGE="~/QGroundControl-x86_64.AppImage"

# Simulator
PX4_TARGET="gz_x500"
GZ_MODE="managed"    # managed or standalone
HEADLESS=0

# Agent
ENABLE_AGENT=1
AGENT_CMD=""
AGENT_ARGS="udp4 -p 8888"

# ROS 2 / offboard
ROS_DISTRO="jazzy"
ENABLE_ROS=1
ROS_SETUP_EXTRA="export RMW_IMPLEMENTATION=rmw_fastrtps_cpp"
OFFBOARD_CMD="ros2 run my_px4_offboard offboard_trajectory"

# QGroundControl
# Set ENABLE_QGC=1 only after the basic start/stop/restart flow is stable.
ENABLE_QGC=0
QGC_ENV=""

# Timing
AGENT_START_WAIT_SECONDS=2
PX4_READY_TIMEOUT=120
QGC_SETTLE_SECONDS=4

# Logs / runtime
LOG_DIR="~/PX4_pro/px4_session_logs"
RUNTIME_DIR="~/PX4_pro/.px4_one_click"
LOG_TERMINAL_MODE="concise"

# Attach behavior
DEFAULT_ATTACH_WINDOW="px4"
PX4_STDIN_MODE="null"

# Gazebo safety
DETECT_EXISTING_GZ=1
FAIL_ON_EXISTING_GZ_IN_MANAGED=1